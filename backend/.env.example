# ==========================================
# NutriMind AI - Backend Environment Variables
# ==========================================

# PostgreSQL Database URL (from Supabase Database Settings)
# Example: postgresql://postgres.xxxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_SUPABASE_PROJECT.supabase.co:5432/postgres"

# Supabase Project Credentials (from Supabase API Settings)
SUPABASE_URL="https://your-project-id.supabase.co"
#"https://your-project-id.supabase.co"
SUPABASE_KEY="your-supabase-service-role-key-or-anon-key"
#"your-supabase-service-role-key-or-anon-key"

# Google Gemini API Key (from Google AI Studio)
# Required for Food Detection, Chat, and Recommendations
GEMINI_API_KEY="your-gemini-api-key"
